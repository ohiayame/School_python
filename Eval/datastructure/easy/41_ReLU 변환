# 조건 표현식을 컴프리헨션 표현식 자리에 둡니다.
data_sets = [
    [-3, 5, -1, 0, 4, -7, 2, -10, 8],
    [-1, -5, -10],
    [10, 20, 30],
]
t = int(input())
data = data_sets[t]

# ReLU: 음수 → 0, 0 이상은 그대로 유지
# 조건 표현식(x if x >= 0 else 0) 형태로 문제 의도를 명시적으로 표현
relu_data = [num if num >= 0 else 0 for num in data]
print(" ".join(map(str, relu_data)))