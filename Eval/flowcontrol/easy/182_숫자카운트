# N을 입력받아 1~N에서 3의 배수, 5의 배수, 공배수 개수를 세어 출력하세요.
n = int(input())

# 1~N에서 3, 5, 15의 배수 계산 (개수 = n // 숫자)
# 1. 3의 배수 개수
count_3 = n // 3
# 2. 5의 배수 개수
count_5 = n // 5
# 3. 3과 5의 공배수(15의 배수) 개수
count_15 = n // 15

# 결과 출력
print(f"3의 배수: {count_3}개")
print(f"5의 배수: {count_5}개")
print(f"3과 5의 공배수: {count_15}개")